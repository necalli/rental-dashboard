# Server
FLASK_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5002
BACKEND_DEBUG=false
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage
RENTAL_DATA_DIR=backend/data
RENTAL_RAW_DIR=backend/raw
RENTAL_DB_PATH=backend/data/rental_dashboard.db

# Geo suggestions (Geoapify autocomplete)
RENTAL_GEOAPIFY_API_KEY=
RENTAL_GEOAPIFY_BASE_URL=https://api.geoapify.com/v1/geocode/autocomplete
RENTAL_GEOAPIFY_LIMIT=6
RENTAL_GEOAPIFY_LANG=en
RENTAL_GEOAPIFY_COUNTRY_CODES=
RENTAL_GEOAPIFY_TIMEOUT=8
RENTAL_GEOAPIFY_CACHE_SECONDS=86400
RENTAL_PAGE_SIZE=50

# Worker
RENTAL_WORKER_POLL_INTERVAL=2
RENTAL_PLAYWRIGHT_HEADLESS=true
RENTAL_PLAYWRIGHT_TIMEOUT_MS=30000
RENTAL_PLAYWRIGHT_WAIT_MS=2500
RENTAL_CAPTURE_ALLOWLIST=airbnb.com
RENTAL_CAPTURE_RESPONSE_DOMAINS=airbnb.com
RENTAL_CAPTURE_RESPONSE_URL_ALLOWLIST=
RENTAL_CAPTURE_HTML=true
RENTAL_CAPTURE_MAX_RESPONSES=200
RENTAL_CAPTURE_TIMEOUT_MS=120000
RENTAL_CAPTURE_TTL_SECONDS=86400
RENTAL_CAPTURE_MIN_INTERVAL_MS=1500
RENTAL_CAPTURE_ERROR_BACKOFF_MS=5000
RENTAL_CAPTURE_INCLUDE_REVIEWS=false
RENTAL_CAPTURE_REVIEW_MODE=lite
RENTAL_CAPTURE_REVIEW_LIMIT=24
RENTAL_CAPTURE_REVIEW_SCROLL_STEPS=4
RENTAL_CAPTURE_REVIEW_SCROLL_PULSES=4
RENTAL_CAPTURE_REVIEW_WAIT_MS=5000
RENTAL_CAPTURE_REVIEW_PAGINATION_PASSES=6
RENTAL_CAPTURE_REVIEW_PAGE_WAIT_MS=1500
RENTAL_CAPTURE_REVIEW_ONLY=false
# If unset, review-only is enabled automatically when RENTAL_CAPTURE_DEBUG=true.
RENTAL_CAPTURE_DEBUG=false
RENTAL_CAPTURE_DEBUG_SCREENSHOTS=false
RENTAL_CAPTURE_BLOCK_RESOURCES=false
RENTAL_CAPTURE_BLOCKED_RESOURCE_TYPES=image,media,font
RENTAL_CAPTURE_BLOCKED_URL_PATTERNS=
RENTAL_CAPTURE_ADAPTIVE_SEARCH_NAV=true
RENTAL_CAPTURE_ADAPTIVE_SEARCH_HTML=true
RENTAL_CAPTURE_SEARCH_RESPONSE_TARGET=10
RENTAL_CAPTURE_ADAPTIVE_WAIT_POLL_MS=120
RENTAL_CAPTURE_SEARCH_NETWORKIDLE_FALLBACK_MS=300
RENTAL_CAPTURE_ADAPTIVE_LISTING_NAV=false
RENTAL_CAPTURE_LISTING_RESPONSE_TARGET=12
RENTAL_CAPTURE_LISTING_NAV_WAIT_CAP_MS=1800
RENTAL_CAPTURE_LISTING_NETWORKIDLE_FALLBACK_MS=700
RENTAL_CAPTURE_LOG_METRICS=false

# LLM enrichment
RENTAL_LLM_API_KEY=
RENTAL_LLM_MODEL=gpt-5-mini
#RENTAL_LLM_MODEL=gpt-4.1-mini-2025-04-14
RENTAL_LLM_BASE_URL=https://api.openai.com/v1
RENTAL_LLM_TIMEOUT=60
RENTAL_LLM_REASONING_EFFORT=minimal
RENTAL_LLM_MAX_OUTPUT_TOKENS=
RENTAL_COMPARE_REQUIRE_MIN_COVERAGE_DEFAULT=false
RENTAL_COMPARE_MIN_COVERAGE_DEFAULT=0.5

# FX rates (USD display)
RENTAL_FX_BASE_URL=https://api.frankfurter.dev/v1
RENTAL_FX_TARGET=USD
RENTAL_FX_TTL_SECONDS=21600
RENTAL_FX_TIMEOUT=10

# Frontend agent chat (Vite)
VITE_API_BASE_URL=http://localhost:5002
VITE_BACKEND_URL=http://localhost:5002
VITE_ALLOWED_HOSTS=.ngrok-free.dev,.ngrok.dev,.ngrok.io
VITE_ENABLE_AGENT_CHAT=false
VITE_AGENT_API_BASE_URL=http://localhost:5002
VITE_RAG_USER_ID=rental-dashboard

# Agent chat guardrails
RENTAL_AGENT_TOOL_TIMEOUT_MS_DEFAULT=1500
RENTAL_AGENT_TOOL_TIMEOUT_MS_OVERRIDES=
RENTAL_AGENT_TOOL_MAX_WORKERS=4
RENTAL_LISTING_COMPARE_TOOL_TIMEOUT_MS=90000

# Agent runtime selection
RENTAL_AGENT_RUNTIME=deterministic
RENTAL_AGENT_FANOUT_ENABLED=false
RENTAL_AGENT_FANOUT_MAX_WORKERS=3
RENTAL_AGENT_FANOUT_TIMEOUT_MS=10000
RENTAL_AGENT_CLEAN_RESPONSE_STYLE=true

# Claude Agent SDK runtime (optional; set RENTAL_AGENT_RUNTIME=agent_sdk)
RENTAL_AGENT_SDK_MODEL=claude-sonnet-4-6
RENTAL_AGENT_SDK_PERMISSION_MODE=default
RENTAL_AGENT_SDK_MCP_SERVER_ALIAS=rental_ops
RENTAL_AGENT_SDK_RESUME_ENABLED=true
RENTAL_AGENT_SDK_CONTINUE_CONVERSATION_ENABLED=true
RENTAL_AGENT_SDK_DISALLOW_BUILTINS=true
# Optional explicit allowlist for Claude built-ins when default deny is enabled.
# Example for skill creation workflows:
# RENTAL_AGENT_SDK_ALLOWED_BUILTINS=Read,Write,Edit,Glob,Grep,Bash,ToolSearch
RENTAL_AGENT_SDK_ALLOWED_BUILTINS=
RENTAL_AGENT_SDK_HOOKS_ENABLED=true
RENTAL_AGENT_SDK_HOOKS_MODE=observability
RENTAL_AGENT_SDK_HOOK_TIMEOUT_SECONDS=45
RENTAL_AGENT_SDK_STRUCTURED_OUTPUT_ENABLED=true
RENTAL_AGENT_SDK_STREAM_PASSTHROUGH_ENABLED=true
RENTAL_AGENT_SDK_MODEL_FIRST_ROUTING=true
RENTAL_AGENT_SDK_SUBAGENTS_ENABLED=true
RENTAL_AGENT_SDK_SUBAGENT_MODEL=haiku
RENTAL_AGENT_SDK_MAX_BUDGET_USD=
RENTAL_AGENT_SDK_CLI_PATH=
RENTAL_AGENT_SDK_NATIVE_SKILLS_ENABLED=true
RENTAL_AGENT_SDK_NATIVE_SKILLS_SYNC_ENABLED=true
RENTAL_AGENT_SDK_NATIVE_SKILLS_SYNC_INTERVAL_SECONDS=30
RENTAL_AGENT_SDK_NATIVE_SKILLS_DIR=.claude/skills
RENTAL_AGENT_SDK_SETTING_SOURCES=project
RENTAL_AGENT_SDK_TOOLS_PRESET=claude_code
# preset|text|none|legacy
RENTAL_AGENT_SDK_SYSTEM_PROMPT_MODE=preset
RENTAL_AGENT_SDK_SYSTEM_PROMPT_PRESET=claude_code
RENTAL_AGENT_SDK_SYSTEM_PROMPT_APPEND=

# Claude runtime (optional; set RENTAL_AGENT_RUNTIME=claude or agent_sdk)
RENTAL_CLAUDE_API_KEY=
RENTAL_CLAUDE_MODEL=claude-sonnet-4-6
RENTAL_CLAUDE_BASE_URL=https://api.anthropic.com/v1
RENTAL_CLAUDE_TIMEOUT_SECONDS=45
RENTAL_CLAUDE_MAX_TURNS=5
RENTAL_CLAUDE_MAX_TOKENS=2000

# Tavily trip research skill (optional)
RENTAL_TAVILY_API_KEY=
RENTAL_TAVILY_BASE_URL=https://api.tavily.com/search
RENTAL_TAVILY_TIMEOUT_SECONDS=15
RENTAL_TRIP_RESEARCH_INCLUDE_DOMAINS=tripadvisor.com
RENTAL_TRIP_RESEARCH_SEARCH_DEPTH=advanced
RENTAL_TRIP_RESEARCH_MAX_RESULTS_DEFAULT=8
RENTAL_TRIP_RESEARCH_MAX_RESULTS_MAX=20
RENTAL_TRIP_RESEARCH_TOOL_TIMEOUT_MS=12000

# Personality RAG memory pipeline (phase 9A)
RENTAL_RAG_DEFAULT_USER_ID=default-user
RENTAL_RAG_MAX_UPLOAD_BYTES=8000000
RENTAL_RAG_CHUNK_CHARS=1200
RENTAL_RAG_CHUNK_OVERLAP=200
RENTAL_RAG_EMBED_PROVIDER=auto
RENTAL_RAG_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RENTAL_RAG_EMBED_DIM=384
RENTAL_RAG_MAX_SCAN_CHUNKS=5000
RENTAL_RAG_DEFAULT_LIMIT=6
RENTAL_RAG_MAX_LIMIT=12
RENTAL_RAG_CONTEXT_TOOL_TIMEOUT_MS=4000
RENTAL_RAG_UPSERT_TOOL_TIMEOUT_MS=8000
RENTAL_RAG_SKILL_ENABLED=true
RENTAL_RAG_SKILL_SCOPE=planning

# Skill packaging
RENTAL_AGENT_SKILLS_DIR=backend/agent_skills
